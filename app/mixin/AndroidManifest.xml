<?xml version="1.0" encoding="utf-8"?>
<!--
  Plain-text manifest patch merged into the target APK's binary AndroidManifest at build time by
  ApkMixin (ManifestMerger). New attributes override old; new nodes are added (matched by element
  name + android:name). Edit freely to declare extra intent-filters / components / permissions.

  Here: let the modded app appear in the system share sheet so it can RECEIVE shared
  text/image/video/audio from other apps. JumpActivity is already exported + the launcher.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application>
        <activity android:name="com.tencent.qqnt.watch.app.JumpActivity">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="audio/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>

        <!--
          Watchdog crash/hang report viewer. Runs in its OWN process (:crash) so it can render
          the report even after the main process dies in a crash. Only string/boolean attributes
          are used here because ApkMixin's ManifestMerger writes enum/reference values (launchMode,
          theme) as raw strings; the activity inherits the app theme and uses launchMode=standard.
        -->
        <activity
            android:name="momoi.mod.qqpro.watchdog.CrashReportActivity"
            android:process=":crash"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity="momoi.mod.qqpro.crash" />

        <!-- In-app debug menu opened from the settings 调试 section. Runs in the main process. -->
        <activity
            android:name="momoi.mod.qqpro.watchdog.DebugActivity"
            android:exported="false"
            android:excludeFromRecents="true" />

        <!-- Watchdog crash/hang test panel, opened from the settings 调试 section. Main process. -->
        <activity
            android:name="momoi.mod.qqpro.watchdog.WatchdogTestActivity"
            android:exported="false"
            android:excludeFromRecents="true" />

        <!-- UI-style chooser (Material vs original), shown on first launch and from settings. Main process. -->
        <activity
            android:name="momoi.mod.qqpro.StyleChooserActivity"
            android:exported="false"
            android:excludeFromRecents="true" />
    </application>

    <!--
      NOTE: do NOT re-declare WRITE_EXTERNAL_STORAGE here. The target APK already declares it
      UNCAPPED, and QQ's own 保存到相册 checks it at runtime. Adding a duplicate with
      android:maxSdkVersion merges onto the existing node (merger: new attributes override old),
      which un-grants storage above that SDK and breaks save-to-album on API > cap
      (checkSelfPermission → denied → "permanently denied"). Log-saving on the API-28 watch is
      already covered by the target's uncapped declaration.
    -->
</manifest>
